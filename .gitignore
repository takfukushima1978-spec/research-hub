node_modules/
package.json
package-lock.json
.env
.env.*
*.log
# .claude 配下は除外するが、プロジェクトスキルは git 管理する
# （security.md: 取り込んだ skill は .claude/skills/ に置き Git 管理。settings.local.json 等の秘密は除外のまま）
# 親ディレクトリ自体を除外すると配下を再包含できないため `.claude/*` で中身を除外する
.claude/*
!.claude/skills/
supabase/.temp/
__pycache__/
*.pyc
token.json
credentials.json

# Console 貼り付け用の secrets 埋め込み済みプロンプト（ローカル専用、絶対に commit しない）
prompts/CONSOLE-READY-*.md

# Deep Research 開発時のスクラッチファイル（テスト出力・使い捨て）
scripts/tmp/

# Cloudflare Workers のビルド成果物・依存
worker/.wrangler/
worker/node_modules/
# ただし worker/ 配下の package.json と package-lock.json は git 管理する
# （ルート側の package.json / package-lock.json は除外設定が継承されるため明示的に許可）
!worker/package.json
!worker/package-lock.json

# 参考資料/ の外部提供 Office 一次資料（尾原コミュニティ等・数十〜100MB超）は生のまま追跡しない
# GitHub の 100MB push 上限に抵触する上、有料コミュニティの著作物を push しない（2026-07-10・R111）
# 自作の md 地図・pptx-diet 圧縮版（*_diet.*）は追跡する
参考資料/*.docx
参考資料/*.pptx
参考資料/*.xlsx
!参考資料/*_diet.docx
!参考資料/*_diet.pptx
!参考資料/*_diet.xlsx
