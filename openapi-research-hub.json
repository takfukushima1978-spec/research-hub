{
  "openapi": "3.1.0",
  "info": {
    "title": "Research Hub API",
    "description": "AI Research Hubの記事投入・Deep Research API",
    "version": "3.1"
  },
  "servers": [
    {
      "url": "https://swgdzytwyvkwvncaqjks.supabase.co/functions/v1"
    }
  ],
  "paths": {
    "/insert-article": {
      "post": {
        "operationId": "insertArticle",
        "summary": "リサーチ記事をResearch Hubに投入する",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "category_name", "body_html", "summary", "source_date"],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "記事タイトル（日本語）"
                  },
                  "category_name": {
                    "type": "string",
                    "description": "カテゴリ識別子。claude_code / ai_accounting / claude_code_official"
                  },
                  "body_html": {
                    "type": "string",
                    "description": "記事本文（HTML形式）"
                  },
                  "summary": {
                    "type": "string",
                    "description": "記事の要約（1-3文）"
                  },
                  "source_date": {
                    "type": "string",
                    "description": "記事の日付（YYYY-MM-DD形式）"
                  },
                  "slug": {
                    "type": "string",
                    "description": "URL用スラッグ（省略時は自動生成）"
                  },
                  "body_text": {
                    "type": "string",
                    "minLength": 1500,
                    "description": "プレーンテキスト版本文（省略時はbody_htmlから自動生成）。品質ノルマ: 1500文字以上 (auto-research-collectでは1500-2500字推奨)。quality_override:true 時は無視。"
                  },
                  "tag_names": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 4,
                    "description": "タグ名の配列。品質ノルマ: 4件以上必須。quality_override:true 時は無視。"
                  },
                  "source_urls": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["url"],
                      "properties": {
                        "url": { "type": "string" },
                        "title": { "type": "string" },
                        "domain": { "type": "string" }
                      }
                    },
                    "minItems": 3,
                    "description": "参照元URL一覧。品質ノルマ: 一次ソース3件以上必須。quality_override:true 時は無視。"
                  },
                  "quality_override": {
                    "type": "boolean",
                    "description": "true を指定すると body_text/source_urls/tag_names の品質ノルマ検証をスキップ。手動投入の緊急回避用。auto-research-collectでは使用しない。"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "記事投入成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "description": "記事ID" },
                    "slug": { "type": "string", "description": "記事スラッグ" }
                  }
                }
              }
            }
          },
          "400": { "description": "バリデーションエラー" },
          "401": { "description": "認証エラー" },
          "429": { "description": "レートリミット超過" }
        }
      }
    },
    "/deep-research": {
      "post": {
        "operationId": "deepResearch",
        "summary": "Deep Researchの未処理リクエスト取得または結果登録",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": {
                    "type": "string",
                    "description": "list_pending: 未処理リクエスト一覧を取得。complete: 調査結果を登録。"
                  },
                  "request_id": {
                    "type": "string",
                    "description": "complete時必須。対象のリクエストID"
                  },
                  "result_summary": {
                    "type": "string",
                    "description": "complete時必須。調査結果の要約（1-3文）"
                  },
                  "result_body": {
                    "type": "string",
                    "description": "complete時必須。調査結果の全文（Markdown形式推奨）"
                  },
                  "result_doc_url": {
                    "type": "string",
                    "description": "関連ドキュメントURL（省略可）"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "requests": {
                      "type": "array",
                      "description": "list_pending時の未処理リクエスト一覧",
                      "items": {
                        "type": "object",
                        "properties": {
                          "request_id": { "type": "string" },
                          "article_id": { "type": "string" },
                          "article_title": { "type": "string" },
                          "focus_point": { "type": "string" },
                          "additional_context": { "type": "string" },
                          "priority": { "type": "integer" }
                        }
                      }
                    },
                    "id": { "type": "string", "description": "complete時の完了リクエストID" },
                    "status": { "type": "string", "description": "complete時: completed" }
                  }
                }
              }
            }
          },
          "400": { "description": "バリデーションエラー" },
          "401": { "description": "認証エラー" }
        }
      }
    }
  }
}
